{
  "name": "pie",
  "displayName": "pie",
  "description": "Native PI coding agent chat and session UI for VSCode",
  "version": "0.3.0",
  "publisher": "pie",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:pie.openChat",
    "onCommand:pie.newSession",
    "onCommand:pie.restartBackend",
    "onCommand:pie.exportRunAnalytics",
    "onView:pie.sessionsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pie",
          "title": "pie",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pie": [
        {
          "type": "webview",
          "id": "pie.sessionsView",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "pie.openChat",
        "title": "pie: Open Chat"
      },
      {
        "command": "pie.newSession",
        "title": "pie: New Session"
      },
      {
        "command": "pie.attachFiles",
        "title": "pie: Attach Selected Files"
      },
      {
        "command": "pie.restartBackend",
        "title": "pie: Restart Backend"
      },
      {
        "command": "pie.exportRunAnalytics",
        "title": "pie: Export Run Analytics"
      },
      {
        "command": "pie.toggleStreamDiag",
        "title": "pie: Toggle Stream Diagnostics"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "pie.attachFiles",
          "when": "resourceScheme == file",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "pie",
      "properties": {
        "pie.nodePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the standalone Node.js executable used to run the PI backend."
        },
        "pie.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the installed PI SDK package directory, such as @earendil-works/pi-coding-agent."
        },
        "pie.experimentAssignment": {
          "type": "string",
          "default": "",
          "description": "Optional experiment/treatment assignment label recorded on new run analytics snapshots."
        },
        "pie.allowInTreeAuth": {
          "type": "boolean",
          "default": false,
          "description": "Allow loading auth credentials from inside a Git working tree."
        }
      }
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:webview": "vite build",
    "watch": "node ./scripts/build.mjs --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test ./test/**/*.test.ts",
    "perf": "tsx ./test/perf/streaming-pipeline.perf.ts",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@preact/signals": "^2.9.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/virtual-core": "^3.14.0",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "autoprefixer": "^10.5.0",
    "dompurify": "^3.2.6",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "happy-dom": "^20.9.0",
    "marked": "^15.0.12",
    "postcss": "^8.5.15",
    "postcss-modules": "^6.0.1",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "immer": "^11.1.8",
    "yaml": "^2.9.0"
  }
}
