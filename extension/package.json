{
  "name": "pi-assistant",
  "displayName": "PI Assistant",
  "description": "Native PI coding agent chat and session UI for VSCode",
  "version": "0.3.0",
  "publisher": "pi-config",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:pi-assistant.openChat",
    "onCommand:pi-assistant.newSession",
    "onCommand:pi-assistant.restartBackend",
    "onView:pi-assistant.sessionsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pi-assistant",
          "title": "PI Assistant",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pi-assistant": [
        {
          "type": "webview",
          "id": "pi-assistant.sessionsView",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "pi-assistant.openChat",
        "title": "PI Assistant: Open Chat"
      },
      {
        "command": "pi-assistant.newSession",
        "title": "PI Assistant: New Session"
      },
      {
        "command": "pi-assistant.attachFiles",
        "title": "PI Assistant: Attach Selected Files"
      },
      {
        "command": "pi-assistant.restartBackend",
        "title": "PI Assistant: Restart Backend"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "pi-assistant.attachFiles",
          "when": "resourceScheme == file",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "PI Assistant",
      "properties": {
        "piAssistant.nodePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the standalone Node.js executable used to run the PI backend."
        },
        "piAssistant.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the installed @mariozechner/pi-coding-agent package directory."
        }
      }
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "test": "tsx --test ./test/**/*.test.ts",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@preact/signals": "^2.9.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "dompurify": "^3.2.6",
    "esbuild": "^0.25.4",
    "marked": "^15.0.12",
    "preact": "^10.29.1",
    "tsx": "^4.19.3",
    "typescript": "^5.4.0"
  }
}
