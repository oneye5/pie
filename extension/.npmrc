# This project uses Preact (via the shims/react package aliasing to preact/compat)
# instead of React. Some devDependencies (e.g. use-undo) declare a peer dep on
# react-dom, which this project deliberately does not install. The lockfile was
# generated with --legacy-peer-deps; this file makes that persistent so a fresh
# `npm install` (including from the pie install.ps1/install.sh bootstrap)
# resolves cleanly under npm 7+ strict peer-dep enforcement.
legacy-peer-deps=true
