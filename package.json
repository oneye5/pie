{
  "name": "pi-config",
  "private": true,
  "//workspaces": "npm workspaces are intentionally NOT enabled. extensions/subagent, extensions/cwd-skills, and extensions/skill-pruner do not yet have package.json files; activating workspaces here would break root npm install. Track enabling this in docs/INSTALLATION_INFRA_PLAN.md.",
  "scripts": {
    "test": "node ./scripts/run-tests.mjs",
    "typecheck": "npm run extension:typecheck && npm run analytics:typecheck",
    "analytics:typecheck": "npm --prefix analysis run typecheck --",
    "analytics:test": "node ./scripts/run-tests.mjs --package analysis",
    "analytics:build-db": "npm --prefix analysis run build-db --",
    "analytics:query": "npm --prefix analysis run query --",
    "analytics:export-site-data": "npm --prefix analysis run export-site-data --",
    "analytics:validate-site-data": "npm --prefix analysis run validate-site-data --",
    "analytics:build-site": "npm --prefix analysis run build-site --",
    "analytics:serve": "npm --prefix analysis run serve --",
    "analytics:validate": "npm --prefix analysis run validate --",
    "extension:build": "npm --prefix extension run build --",
    "extension:test": "node ./scripts/run-tests.mjs --package extension",
    "extension:typecheck": "npm --prefix extension run typecheck --",
    "extensions:test": "node ./scripts/run-tests.mjs --package cwd-skills --package safeguard --package skill-pruner --package subagent"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.3"
  }
}
