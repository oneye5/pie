# PI local runtime data and auth files
auth.json
auth.json.*
*.auth.json
/data/

# Legacy repo-local PI runtime dirs kept ignored for compatibility
# (root /pie/ is old local runtime data, not the tracked VS Code extension source under /extension/)
/sessions/
/pie/

# Legacy local export drop locations kept ignored for compatibility
/run-analytics-export.json

# Environment files
.env
.env.*
*.env

# PI-managed binaries and package caches
/bin/
/git/
/npm/

# Package manager artifacts
node_modules/
.pnpm-store/
.pnpm-debug.log

# Note: keep lockfiles (package-lock.json, yarn.lock, pnpm-lock.yaml) tracked

# Package build artifacts
/extension/out/
/analysis/site/dist/
*.vsix

# Build / test caches
coverage/
.nyc_output/
*.tsbuildinfo
out-tsc/
.tmp/
.temp/
.cache/
.parcel-cache/
.eslintcache

# Stale TypeScript emit alongside source (build outputs to /extension/out/)
extension/src/**/*.js
extension/src/**/*.js.map
extension/test/*.js
extension/test/*.js.map
extension/test-results/

# Analysis package generated outputs
/analysis/data/*.duckdb
/analysis/data/*.duckdb.*
/analysis/data/exports/
/analysis/data/tmp-site-data/
/analysis/site/data/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS artifacts
Thumbs.db
.DS_Store
desktop.ini
ehthumbs.db
# Windows null device (created when redirecting to uninitialized variable in batch/PowerShell)
nul

# Editor / IDE artifacts
*.swp
*.swo
.idea/
.vscode-test/
# NOTE: this repo keeps a committed .vscode/ (workspace settings/tasks/extensions).
# If you want to ignore all local VS Code state, uncomment the next line:
# .vscode/

# Installer-generated backups
/settings.json.session-dir.*.bak
