# Force LF line endings on shell scripts so they run on Linux/macOS even when
# checked out on Windows with core.autocrlf=true (otherwise CRLF breaks bash:
#   $'\r': command not found  /  syntax error near unexpected token).
*.sh     text eol=lf
install.sh text eol=lf

# PowerShell scripts are fine with CRLF on Windows (the only platform that runs
# them), but normalize to CRLF so they always work under Invoke-Expression /
# Set-ExecutionPolicy regardless of how they were committed.
*.ps1    text eol=crlf
*.psm1   text eol=crlf
